  },
  {
    "id": "fn_alert_router_1",
    "type": "function",
    "z": "tab_solar_el",
    "name": "Route OPEN alerts",
    "func": "const result = Array.isArray(msg.payload) ? msg.payload[0] : msg.payload;\n\nif (!result || !result.state) {\n    return [null, msg];\n}\n\nmsg.alert = result;\n\nif (result.state === \"OPEN\") {\n    return [msg, null];\n}\n\nreturn [null, msg];",
    "outputs": 2,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
