  },
  {
    "id": "fn_validate_enrich_1",
    "type": "function",
    "z": "tab_solar_el",
    "name": "Validate and map inspection",
    "func": "const p = msg.payload || {};\n\nif (typeof p.severity_score !== \"number\") {\n    node.warn(\"Dropped message: missing severity_score\");\n    return null;\n}\n\nif (!p.pad_id) {\n    node.warn(\"Dropped message: missing pad_id\");\n    return null;\n}\n\nconst panelId = p.panel_id || \"panel_A\";\nconst robotId = p.robot_id || \"robot_01\";\nconst modelVersion = p.model_version || \"onnx_v1\";\n\nconst inspection = {\n    captured_at: new Date().toISOString(),\n    robot_id: robotId,\n    panel_id: panelId,\n    pad_id: p.pad_id,\n    severity_score: Number(p.severity_score),\n    status: p.status || \"OK\",\n    image_path: p.image_path || null,\n    model_version: modelVersion,\n    raw_payload: p\n};\n\nmsg.inspection = inspection;\nmsg.panel_id = panelId;\nmsg.pad_id = p.pad_id;\nmsg.payload = inspection;\n\nconst supabaseUrl = env.get(\"SUPABASE_URL\");\nconst serviceRoleKey = env.get(\"SUPABASE_SERVICE_ROLE_KEY\");\n\nif (!supabaseUrl || !serviceRoleKey) {\n    node.error(\"SUPABASE_URL or SUPABASE_SERVICE_ROLE_KEY not configured\", msg);\n    return null;\n}\n\nmsg.url = `${supabaseUrl}/rest/v1/inspections`;\nmsg.headers = {\n    apikey: serviceRoleKey,\n    Authorization: `Bearer ${serviceRoleKey}`,\n    \"Content-Type\": \"application/json\",\n    Prefer: \"return=representation\"\n};\n\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 590,
    "y": 120,
    "wires": [["http_insert_inspection_1"]]
  },
  {
    "id": "http_insert_inspection_1",
    "type": "http request",
    "z": "tab_solar_el",
    "name": "Insert inspection",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "",
    "tls": "",
    "persist": false,
    "proxy": "",
    "insecureHTTPParser": false,
    "authType": "",
    "senderr": true,
    "headers": [],
    "x": 800,
    "y": 120,
    "wires": [["fn_prepare_rpc_1"]]
  },
  {
    "id": "fn_prepare_rpc_1",
    "type": "function",
    "z": "tab_solar_el",
    "name": "Prepare evaluate_pad_alert RPC",
    "func": "const supabaseUrl = env.get(\"SUPABASE_URL\");\nconst serviceRoleKey = env.get(\"SUPABASE_SERVICE_ROLE_KEY\");\n\nmsg.url = `${supabaseUrl}/rest/v1/rpc/evaluate_pad_alert`;\nmsg.headers = {\n    apikey: serviceRoleKey,\n    Authorization: `Bearer ${serviceRoleKey}`,\n    \"Content-Type\": \"application/json\"\n};\nmsg.payload = {\n    p_panel_id: msg.panel_id,\n    p_pad_id: msg.pad_id\n};\n\nreturn msg;",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1030,
    "y": 120,
    "wires": [["http_eval_alert_1"]]
  },
