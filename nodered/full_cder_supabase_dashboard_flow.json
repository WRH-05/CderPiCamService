  {
    "id": "fn_format_open_count",
    "type": "function",
    "z": "9a8200fd1fbb9ecd",
    "name": "Format open alert count",
    "func": "let count = 0;\nif (Array.isArray(msg.payload)) {\n    count = msg.payload.length;\n} else if (msg.payload && Array.isArray(msg.payload.value)) {\n    count = msg.payload.value.length;\n}\nmsg.payload = String(count);\nreturn msg;",
