        "id": "25cecb407abb9130",
        "type": "function",
        "z": "14a6af89eabdc1b0",
        "name": "Map selected inspection to UI",
        "func": "const row = Array.isArray(msg.payload) ? msg.payload[0] : msg.payload;\nconst selectedPanel = (msg.meta && msg.meta.panel_id) || flow.get('selected_panel_id') || 'panel_1';\nconst selectedPad = (msg.meta && msg.meta.pad_id) || flow.get('selected_pad_id') || 'pad_01';\nif (!row) {\n  msg.payload = {\n    panel_id: selectedPanel,\n    pad_id: selectedPad,\n    status: 'NO DATA',\n    severity_score: 0,\n    robot_id: '-',\n    model_version: '-',\n    image_path: null,\n    captured_at: null,\n    record_panel_id: null,\n    record_pad_id: null\n  };\n  msg.meta = { panel_id: selectedPanel, pad_id: selectedPad, no_data: true };\n  return msg;\n}\nmsg.payload = {\n  panel_id: selectedPanel,\n  pad_id: selectedPad,\n  status: row.status || '—',\n  severity_score: row.severity_score,\n  robot_id: row.robot_id || '—',\n  model_version: row.model_version || '—',\n  image_path: row.image_path || null,\n  captured_at: row.captured_at || null,\n  record_panel_id: row.panel_id || null,\n  record_pad_id: row.pad_id || null\n};\nmsg.meta = { panel_id: selectedPanel, pad_id: selectedPad, record_panel_id: row.panel_id || null, record_pad_id: row.pad_id || null };\nreturn msg;",
