    {
        "id": "d1985987beca0b6b",
        "type": "function",
        "z": "14a6af89eabdc1b0",
        "name": "Query selected pad from DB",
        "func": "// Store selected values\nif (msg.topic === 'panel_id') flow.set('selected_panel_id', msg.payload);\nif (msg.topic === 'pad_id') flow.set('selected_pad_id', msg.payload);\nif (msg.topic === 'mode') flow.set('selected_mode', msg.payload);\n\nconst panelId = flow.get('selected_panel_id') || msg.payload || 'panel_1';\nconst padId = flow.get('selected_pad_id') || 'pad_01';\n\nconst supabaseUrl = env.get('SUPABASE_URL');\nconst serviceRoleKey = env.get('SUPABASE_SERVICE_ROLE_KEY');\nif (!supabaseUrl || !serviceRoleKey) {\n  node.warn('SUPABASE_URL or SUPABASE_SERVICE_ROLE_KEY not configured');\n  return null;\n}\n\nmsg.meta = { panel_id: panelId, pad_id: padId, source: 'db_filter' };\nmsg.url = `${supabaseUrl}/rest/v1/inspections?select=*&panel_id=eq.${encodeURIComponent(panelId)}&pad_id=eq.${encodeURIComponent(padId)}&order=captured_at.desc&limit=1`;\nmsg.method = 'GET';\nmsg.headers = { apikey: serviceRoleKey, Authorization: `Bearer ${serviceRoleKey}` };\nreturn msg;",
