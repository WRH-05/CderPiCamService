        "type": "function",
        "z": "b9c24d8bf2d94ba1",
        "name": "Build pad options (24)",
        "func": "const selectedPanel = msg.payload || flow.get('selected_panel_id') || 'panel_1';\nflow.set('selected_panel_id', selectedPanel);\nconst options = [];\nfor (let i = 1; i <= 24; i++) {\n  const value = `pad_${String(i).padStart(2, '0')}`;\n  options.push({ label: `Pad ${String(i).padStart(2, '0')}`, value });\n}\nlet selectedPad = flow.get('selected_pad_id') || 'pad_01';\nif (!options.find(o => o.value === selectedPad)) selectedPad = 'pad_01';\nflow.set('selected_pad_id', selectedPad);\nconst toPadDropdown = { options, payload: selectedPad, topic: 'pad_id' };\nconst toQuery = { payload: selectedPad, topic: 'pad_id' };\nreturn [toPadDropdown, toQuery];",
