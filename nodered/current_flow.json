        "height": "4",
        "format": "<style>\n.nr-dashboard-theme { background: linear-gradient(180deg, #f4f7fb 0%, #e7edf5 100%); }\n.nr-dashboard-theme md-content { background: transparent; }\n.nr-dashboard-theme md-card { border-radius: 18px; box-shadow: 0 10px 30px rgba(15, 23, 42, 0.10); border: 1px solid rgba(148, 163, 184, 0.18); overflow: hidden; }\n.nr-dashboard-theme .nr-dashboard-cardtitle { font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #334155; }\n.nr-dashboard-theme .nr-dashboard-cardcontainer { padding-top: 4px; padding-bottom: 4px; }\n.dashboard-hero { padding: 18px 22px; border-radius: 20px; background: linear-gradient(135deg, #10253f 0%, #1f3b63 55%, #3563a8 100%); color: #ffffff; }\n.dashboard-hero__eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.82; }\n.dashboard-hero h1 { margin: 8px 0 0; font-size: 26px; line-height: 1.1; }\n.dashboard-hero p { margin: 8px 0 0; max-width: 720px; font-size: 14px; line-height: 1.5; opacity: 0.88; }\n.dashboard-hero__chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }\n.dashboard-hero__chips span { display: inline-flex; align-items: center; padding: 6px 10px; border-radius: 999px; background: rgba(255, 255, 255, 0.14); border: 1px solid rgba(255, 255, 255, 0.18); font-size: 12px; font-weight: 600; letter-spacing: 0.02em; }\n</style>\n<div class='dashboard-hero'>\n  <div class='dashboard-hero__eyebrow'>Realtime inspection dashboard</div>\n  <h1>CDER Pi Camera Service</h1>\n  <p>MQTT intake, Supabase persistence, and alert routing in one view. Use this tab to monitor severity, trace the current pad, and confirm alert state at a glance.</p>\n  <div class='dashboard-hero__chips'>\n    <span>MQTT ingest</span>\n    <span>Severity trend</span>\n    <span>Supabase write</span>\n    <span>Open alerts</span>\n  </div>\n</div>",
